# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.claude/
# ─── Lock files (generated locally, avoid cross-OS conflicts in Docker) ───────
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/
.next/
out/

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Allow example/template env files
!.env.example
!.env.docker

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Docker ───────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore local overrides
docker-compose.override.yml

# ─── Misc ─────────────────────────────────────────────────────────────────────
.cache/
.turbo/
*.local
